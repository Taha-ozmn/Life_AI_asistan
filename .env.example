# =============================================================================
# Life+ — ortam degiskenleri (SABLON)
# Kopyala:  cp .env.example .env
# Sonra asagidaki yer tutuculari GERCEK degerlerle degistir. Bu dosyada
# gercek API anahtari birakma; .env dosyasi .gitignore ile takip disidir.
# =============================================================================

# Flask oturum cerezi (zorunlu). Uzun rastgele metin: openssl rand -hex 32
FLASK_SECRET_KEY=degistir-uzun-rastgele-gizli-metin

# Sohbet arsivi SQLite yolu (bos birakilirsa: <proje>/instance/nutricoach.db)
# NUTRICOACH_DB=/tmp/nutricoach.db

# ---------------------------------------------------------------------------
# Yapay zeka saglayicisi: groq | openai | gemini
# Not: Bulutta "tamamen sinirsiz ve ucretsiz" API yok; Groq ucretsiz katman RPM limitli,
# tam kontrol icin yerelde Ollama kullanilabilir.
# ---------------------------------------------------------------------------

# --- Groq (AI_PROVIDER=groq) — cok hizli, ucretsiz anahtar: console.groq.com ---
# AI_PROVIDER=groq
# GROQ_API_KEY=gsk-buraya-groq-anahtari
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.1-8b-instant
# AI_MODEL_FALLBACKS=llama-3.3-70b-versatile

AI_PROVIDER=gemini

# --- Google AI (AI_PROVIDER=gemini) ---
# Anahtar: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-buraya-google-ai-studio-anahtari

# Model (bos birakilirsa uygulama gemini-2.0-flash kullanir).
# Hiz onceligi: gemini-2.0-flash-lite -> gemini-2.0-flash
# Daha guc: gemini-2.5-flash | gemini-3-flash-preview
AI_MODEL=gemini-2.0-flash-lite

# Cikti tokeni (256 ile saglayici tavanı arası). Daha hizli kisa yanit: 1024-1200.
# Uzun tarif/liste icin: 2048-4096 veya AI_MAX_OUTPUT_TOKENS=max
# AI_MAX_OUTPUT_TOKENS=1024
#
# Birincil model kotaya takilirsa sirayla dene (virgulle):
# AI_MODEL_FALLBACKS=gemini-1.5-flash,gemini-2.5-flash
#
# Yanit stili: dusuk = daha oz ve tipik olarak daha cabuk (0.35-0.55 iyi baslangic)
# AI_TEMPERATURE=0.45

# Model baglami (SQLite tam tutar; API kotasi icin son mesajlar):
# AI_HISTORY_MESSAGES=all
# Kucuk deger = hizli (or. 48); buyuk = daha cok hatirlama (yavas):
# AI_MAX_CONTEXT_MESSAGES=48
# Tarayici oturumunda saklanan son mesaj (cerez; UI icin):
# AI_SESSION_MESSAGES=150

# Tek API istegi icin sunucu zaman asimi (saniye); uzun tariflerde 240-300 denenebilir
# AI_REQUEST_TIMEOUT_SECONDS=180

# --- OpenAI (AI_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-buraya-openai-anahtari
# AI_MODEL=gpt-4.1-mini

# Not: .env degistirdikten sonra sunucuyu durdurup yeniden baslat (python3 app.py).
